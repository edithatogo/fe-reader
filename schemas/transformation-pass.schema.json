{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.fereader.org/transformation-pass.schema.json",
  "title": "Fe Reader Transformation Graph",
  "type": "object",
  "required": [
    "graph_id",
    "input_document_sha256",
    "passes",
    "expected_write_mode"
  ],
  "additionalProperties": false,
  "properties": {
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "input_document_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "passes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pass"
      }
    },
    "expected_write_mode": {
      "enum": [
        "IncrementalAppend",
        "FullRewrite",
        "FullSanitizingRewrite"
      ]
    }
  },
  "$defs": {
    "pass": {
      "type": "object",
      "required": [
        "pass_id",
        "pass_type",
        "maturity",
        "inputs",
        "outputs",
        "policy_risk",
        "parameters"
      ],
      "additionalProperties": false,
      "properties": {
        "pass_id": {
          "type": "string",
          "minLength": 1
        },
        "pass_type": {
          "type": "string",
          "minLength": 1
        },
        "maturity": {
          "enum": [
            "Experimental",
            "Preview",
            "Stable"
          ]
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "policy_risk": {
          "enum": [
            "ReadOnly",
            "LowMutation",
            "HighRiskMutation",
            "SecurityCritical"
          ]
        },
        "parameters": true
      }
    }
  }
}
