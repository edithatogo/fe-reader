{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MetadataOperation",
  "type": "object",
  "required": [
    "operation_id",
    "mode"
  ],
  "properties": {
    "operation_id": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "view",
        "edit",
        "diff",
        "clean_share",
        "forensic_preserve",
        "provenance_preview",
        "provenance_author"
      ]
    },
    "fields": {
      "type": "object"
    },
    "xmp": {
      "type": "object"
    },
    "scrub_profile": {
      "type": "string"
    }
  }
}
