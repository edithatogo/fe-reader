{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ApplicationIntegrationDescriptor",
  "type": "object",
  "required": [
    "integration_id",
    "display_name",
    "version",
    "direction",
    "capabilities",
    "requires_network",
    "requires_user_grant"
  ],
  "properties": {
    "integration_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "direction": {
      "enum": [
        "import",
        "export",
        "bidirectional"
      ]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_network": {
      "type": "boolean"
    },
    "requires_user_grant": {
      "type": "boolean"
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
