{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "ArchitectureDecisionRecord",
  "required": [
    "adr_id",
    "title",
    "status",
    "decision",
    "consequences"
  ],
  "properties": {
    "adr_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "proposed",
        "accepted",
        "superseded",
        "rejected"
      ]
    },
    "decision": {
      "type": "string"
    },
    "consequences": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}