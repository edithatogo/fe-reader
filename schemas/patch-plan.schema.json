{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PatchPlan",
  "type": "object",
  "required": [
    "plan_id",
    "intent_id",
    "document_id",
    "summary",
    "operations",
    "write_mode",
    "risk_level",
    "approved_for_apply"
  ],
  "additionalProperties": false,
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "intent_id": {
      "type": "string"
    },
    "document_id": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "operations": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "op"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "noop"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "key",
              "value"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "set_metadata"
              },
              "key": {
                "type": "string",
                "minLength": 1,
                "description": "metadata_scrub_mode requires sanitizing_rewrite"
              },
              "value": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "page_index",
              "region"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "redact_region"
              },
              "page_index": {
                "type": "integer",
                "minimum": 0
              },
              "region": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "page_index",
              "stamp_ref"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "place_stamp"
              },
              "page_index": {
                "type": "integer",
                "minimum": 0
              },
              "stamp_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "page_indexes"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "delete_pages"
              },
              "page_indexes": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 0
                },
                "minItems": 1
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "page_indexes",
              "rotation_degrees"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "rotate_pages"
              },
              "page_indexes": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 0
                },
                "minItems": 1
              },
              "rotation_degrees": {
                "enum": [
                  0,
                  90,
                  180,
                  270
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "new_order"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "reorder_pages"
              },
              "new_order": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 0
                },
                "minItems": 1
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "page_index",
              "rects",
              "color"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "add_highlight_annotation"
              },
              "page_index": {
                "type": "integer",
                "minimum": 0
              },
              "rects": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/page_rect"
                },
                "minItems": 1
              },
              "color": {
                "$ref": "#/$defs/annotation_color"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "page_index",
              "position",
              "contents"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "add_note_annotation"
              },
              "page_index": {
                "type": "integer",
                "minimum": 0
              },
              "position": {
                "$ref": "#/$defs/page_point"
              },
              "contents": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              }
            }
          }
        ]
      },
      "minItems": 1
    },
    "write_mode": {
      "enum": [
        "no_write",
        "incremental_append",
        "full_rewrite",
        "sanitizing_rewrite"
      ]
    },
    "risk_level": {
      "enum": [
        "read_only",
        "local_state",
        "document_mutation",
        "high_risk"
      ]
    },
    "transformation_graph_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "transformation_passes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approved_for_apply": {
      "type": "boolean"
    }
  },
  "$defs": {
    "page_rect": {
      "type": "object",
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "page_point": {
      "type": "object",
      "required": [
        "x",
        "y"
      ],
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        }
      }
    },
    "annotation_color": {
      "type": "object",
      "required": [
        "red",
        "green",
        "blue"
      ],
      "additionalProperties": false,
      "properties": {
        "red": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "green": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "blue": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        }
      }
    }
  }
}
