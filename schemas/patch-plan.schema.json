{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PatchPlan",
  "type": "object",
  "required": [
    "plan_id",
    "intent_id",
    "document_id",
    "summary",
    "operations",
    "write_mode",
    "risk_level",
    "approved_for_apply"
  ],
  "additionalProperties": false,
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "intent_id": {
      "type": "string"
    },
    "document_id": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "operations": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "op"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "noop"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "key",
              "value"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "set_metadata"
              },
              "key": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "page_index",
              "region"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "redact_region"
              },
              "page_index": {
                "type": "integer",
                "minimum": 0
              },
              "region": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "page_index",
              "stamp_ref"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "place_stamp"
              },
              "page_index": {
                "type": "integer",
                "minimum": 0
              },
              "stamp_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "page_indexes"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "delete_pages"
              },
              "page_indexes": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 0
                },
                "minItems": 1
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "page_indexes",
              "rotation_degrees"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "rotate_pages"
              },
              "page_indexes": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 0
                },
                "minItems": 1
              },
              "rotation_degrees": {
                "enum": [
                  0,
                  90,
                  180,
                  270
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "new_order"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "const": "reorder_pages"
              },
              "new_order": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 0
                },
                "minItems": 1
              }
            }
          }
        ]
      },
      "minItems": 1
    },
    "write_mode": {
      "enum": [
        "no_write",
        "incremental_append",
        "full_rewrite",
        "sanitizing_rewrite"
      ]
    },
    "risk_level": {
      "enum": [
        "read_only",
        "local_state",
        "document_mutation",
        "high_risk"
      ]
    },
    "approved_for_apply": {
      "type": "boolean"
    }
  }
}
