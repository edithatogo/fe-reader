{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fereader.org/schemas/file-format-version.schema.json",
  "title": "Fe Reader Sidecar Format Version",
  "type": "object",
  "required": [
    "family",
    "version"
  ],
  "properties": {
    "family": {
      "enum": [
        "feworkspace",
        "fereceipt",
        "fereview",
        "fetemplate",
        "feprofile",
        "feindex"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "minimum_reader_version": {
      "type": "string"
    },
    "migration_required": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}