{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "title": "ReleaseEvidenceBundle",
  "required": [
    "release_id",
    "channel",
    "source_commit",
    "toolchain",
    "artifacts"
  ],
  "properties": {
    "release_id": {
      "type": "string"
    },
    "channel": {
      "enum": [
        "dev",
        "nightly",
        "preview",
        "beta",
        "stable",
        "lts",
        "store_submission"
      ]
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "toolchain": {
      "type": "string",
      "minLength": 1
    },
    "source_tag": {
      "type": [
        "string",
        "null"
      ]
    },
    "workflow_run": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workflow_ref": { "type": "string" },
        "run_id": { "type": "string" },
        "run_attempt": { "type": "string" },
        "ref": { "type": "string" },
        "sha": { "type": "string" },
        "actor": { "type": "string" },
        "repository": { "type": "string" }
      }
    },
    "builder": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "workflow": { "type": "string" }
      }
    },
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256",
          "kind"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "pass",
              "advisory",
              "waived"
            ]
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "sbom_path": {
      "type": "string"
    },
    "provenance_path": {
      "type": "string"
    },
    "signing_readiness_path": {
      "type": "string"
    }
  }
}
