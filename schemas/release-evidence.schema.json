{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "title": "ReleaseEvidenceBundle",
  "required": [
    "release_id",
    "channel",
    "source_commit",
    "toolchain",
    "artifacts"
  ],
  "properties": {
    "release_id": {
      "type": "string"
    },
    "channel": {
      "enum": [
        "dev",
        "nightly",
        "preview",
        "beta",
        "stable",
        "lts",
        "store_submission"
      ]
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "toolchain": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256",
          "kind"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "pass",
              "advisory",
              "waived"
            ]
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "sbom_path": {
      "type": "string"
    },
    "provenance_path": {
      "type": "string"
    }
  }
}
