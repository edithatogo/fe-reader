{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fe Reader Search Index Record",
  "type": "object",
  "required": [
    "document_id",
    "document_sha256",
    "page_index",
    "span_id",
    "text",
    "bbox"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "document_sha256": {
      "type": "string"
    },
    "page_index": {
      "type": "integer",
      "minimum": 0
    },
    "span_id": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "bbox": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "number"
      }
    },
    "reading_order": {
      "type": "integer"
    },
    "language_hint": {
      "type": "string"
    }
  },
  "additionalProperties": false
}