{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/edithatogo/fe-reader/schemas/pdf-parity-registry.schema.json",
  "title": "PdfParityRegistry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_version",
    "feature_gate",
    "mutation_pipeline",
    "support_levels",
    "evidence_classes",
    "oracle_requirements",
    "families",
    "claims"
  ],
  "properties": {
    "registry_version": {
      "type": "string",
      "minLength": 1
    },
    "feature_gate": {
      "type": "string",
      "minLength": 1
    },
    "mutation_pipeline": {
      "type": "string",
      "minLength": 1
    },
    "support_levels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "stable",
          "beta",
          "preview",
          "plan_only",
          "oracle_only",
          "blocked",
          "documented_limitation"
        ]
      },
      "minItems": 1
    },
    "evidence_classes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "oracle_requirements": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "families": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "description", "default_support_level"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "default_support_level": {
            "type": "string",
            "enum": [
              "stable",
              "beta",
              "preview",
              "plan_only",
              "oracle_only",
              "blocked",
              "documented_limitation"
            ]
          }
        }
      },
      "minItems": 1
    },
    "claims": {
      "type": "array",
      "items": { "$ref": "pdf-parity-claim.schema.json" },
      "minItems": 1
    }
  }
}
