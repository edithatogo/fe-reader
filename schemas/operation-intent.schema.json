{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OperationIntent",
  "type": "object",
  "required": [
    "intent_id",
    "source",
    "document_id",
    "document_fingerprint",
    "kind",
    "label",
    "risk_level",
    "requires_review"
  ],
  "additionalProperties": false,
  "properties": {
    "intent_id": {
      "type": "string"
    },
    "source": {
      "enum": [
        "ui",
        "cli",
        "mcp",
        "automation",
        "web",
        "plugin"
      ]
    },
    "document_id": {
      "type": "string"
    },
    "document_fingerprint": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "sha256_hex",
        "byte_len"
      ],
      "additionalProperties": false,
      "properties": {
        "sha256_hex": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "byte_len": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "kind": {
      "oneOf": [
        {
          "enum": [
            "inspect",
            "render",
            "search",
            "plan_mutation",
            "apply_patch",
            "export",
            "plugin_proposal",
            "external_tool"
          ]
        },
        {
          "type": "object",
          "required": [
            "custom"
          ],
          "additionalProperties": false,
          "properties": {
            "custom": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "risk_level": {
      "enum": [
        "read_only",
        "local_state",
        "document_mutation",
        "high_risk"
      ]
    },
    "requires_review": {
      "type": "boolean"
    }
  }
}
