{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fe Reader Cache Manifest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "manifest_version": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "privacy_policy": {
      "type": "string"
    },
    "created_at_utc": {
      "type": "string"
    }
  },
  "required": [
    "manifest_version",
    "entries"
  ]
}
